# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in your values
# NEVER commit the real .env file to version control
# ─────────────────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=your-strong-random-secret-key-here   # Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
DEBUG=False                                       # Set to True only during local development
PORT=5000

# AI Provider — choose one: gemini | openai | claude
AI_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Anthropic Claude
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-5

# Database (optional — defaults to SQLite)
# DATABASE_URL=sqlite:///priceai.db
# DATABASE_URL=postgresql://user:password@localhost:5432/priceai
